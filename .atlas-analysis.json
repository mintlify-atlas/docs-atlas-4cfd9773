{
  "projectType": "sdk-library",
  "projectName": "ElastomerClient",
  "projectDescription": "A low-level Ruby gem providing a direct, one-to-one mapping to the Elasticsearch HTTP API with support for indexing, searching, cluster management, bulk operations, and cross-cluster replication.",
  "theme": "luma",
  "primaryColor": "#0dabc7",
  "lightColor": "#8bc404",
  "darkColor": "#eebf42",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "configuration"
            ]
          },
          {
            "group": "Core API",
            "pages": [
              "api/client",
              "api/index",
              "api/docs",
              "api/cluster",
              "api/nodes",
              "api/templates"
            ]
          },
          {
            "group": "Advanced Features",
            "pages": [
              "advanced/bulk-indexing",
              "advanced/multi-search",
              "advanced/scan-scroll",
              "advanced/reindex",
              "advanced/tasks"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/snapshots",
