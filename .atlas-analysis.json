              "development/changelog"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "One-to-one mapping of the Elasticsearch HTTP API",
    "Index management: create, delete, update settings and mappings",
    "Document operations: index, get, search, delete, update",
    "Cluster health, state, and settings management",
    "Bulk indexing with block-based DSL and streaming support",
    "Scan/scroll iterators for paginating large result sets",
    "Multi-search for batching multiple queries in one request",
    "Snapshot and restore for backup and disaster recovery",
    "Cross-cluster replication (CCR) support",
    "ActiveSupport notifications integration for instrumentation",
    "Request body compression and Opaque ID header support",
    "Configurable Faraday HTTP adapter (Net::HTTP, Excon, etc.)",
    "Strict parameter validation against versioned REST API specs"
  ],
  "publicApiSurface": [
    "ElastomerClient::Client.new(host:, port:, url:, adapter:, ...)",
    "client.ping / client.available?",
    "client.version / client.semantic_version",
    "client.index(name) => Index",
    "client.docs(name, type) => Docs",
    "client.cluster => Cluster",
    "client.nodes(node_id) => Nodes",
    "client.bulk(body, params) { |b| ... }",
    "client.multi_search(body, params) { |m| ... }",
    "client.scroll(query, opts) => Scroller",
    "client.scan(query, opts) => Scroller",
    "client.snapshot(repository, name) => Snapshot",
    "client.ccr => Ccr",
    "client.tasks => Tasks",
    "client.reindex(body, params) => Hash",
    "ElastomerClient::Notifications (ActiveSupport instrumentation)",
    "ElastomerClient::Client::Error and subclasses (fatal?/retry?)"
  ]
}
